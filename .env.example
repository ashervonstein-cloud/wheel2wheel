# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Your PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example: postgresql://postgres:password@localhost:5432/wheel2wheel
# Hosted example (Supabase, Neon, etc): get this from your provider's dashboard
DATABASE_URL="postgresql://postgres:password@localhost:5432/wheel2wheel"

# Secret key for signing login tokens - make this long and random
# Generate one at: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="replace-this-with-a-long-random-string"

# The URL your app runs at
NEXTAUTH_URL="http://localhost:3000"

# Email notifications (optional for now - use Gmail or any SMTP provider)
# EMAIL_SERVER_HOST="smtp.gmail.com"
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER="your@gmail.com"
# EMAIL_SERVER_PASSWORD="your-app-password"
# EMAIL_FROM="noreply@wheel2wheel.com"
